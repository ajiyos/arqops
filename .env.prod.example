# =============================================================================
# ArqOps Production Environment Variables
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.
# =============================================================================

# --- Database (DigitalOcean Managed PostgreSQL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://private-db-host.db.ondigitalocean.com:25060/architect_saas?sslmode=require
SPRING_DATASOURCE_USERNAME=doadmin
SPRING_DATASOURCE_PASSWORD=replace_with_managed_db_password

# --- JWT ---
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# --- Google Drive (OAuth callback & redirects — same for all tenants) ---
# Each tenant enters their own OAuth client ID/secret in app Settings. Every tenant must register this exact redirect URI in Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_URI=https://api.arqops.in/api/v1/tenant/storage/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=https://app.arqops.in/settings/profile?google_drive=connected
GOOGLE_OAUTH_ERROR_REDIRECT=https://app.arqops.in/settings/profile?google_drive=error

# --- Email: Resend SMTP (https://resend.com/docs/send-with-smtp) ---
# API key: Resend dashboard → API Keys → create key (starts with re_). Use it as the SMTP password.
# Username must be exactly: resend
# From: a domain or address you verified in Resend (Domains / onboarding@resend.dev for testing).
SPRING_MAIL_HOST=smtp.resend.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=resend
SPRING_MAIL_PASSWORD=re_replace_with_resend_api_key
# From header (verified in Resend). Same as SPRING_MAIL_FROM or use MAIL_FROM_ADDRESS instead.
SPRING_MAIL_FROM=noreply@yourdomain.com

# --- Application Encryption ---
APP_ENCRYPTION_KEY=replace_with_32_byte_base64_encoded_key

# --- Docker Image Config ---
DOCKER_REGISTRY=registry.digitalocean.com/arqops
IMAGE_TAG=latest

# --- Caddy / Domain ---
APP_DOMAIN=app.arqops.com
API_DOMAIN=api.arqops.com
PUBLIC_API_URL=https://api.arqops.com
CORS_ORIGIN=https://app.arqops.com
ACME_EMAIL=admin@arqops.com
