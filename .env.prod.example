# =============================================================================
# ArqOps Production Environment Variables
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.
# =============================================================================

# --- Database (DigitalOcean Managed PostgreSQL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://private-db-host.db.ondigitalocean.com:25060/architect_saas?sslmode=require
SPRING_DATASOURCE_USERNAME=doadmin
SPRING_DATASOURCE_PASSWORD=replace_with_managed_db_password

# --- JWT ---
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# --- Google Drive (OAuth callback & redirects — same for all tenants) ---
# Each tenant enters their own OAuth client ID/secret in app Settings. Every tenant must register this exact redirect URI in Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_URI=https://api.arqops.com/api/v1/tenant/storage/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=https://arqops.com/settings/profile?google_drive=connected
GOOGLE_OAUTH_ERROR_REDIRECT=https://arqops.com/settings/profile?google_drive=error

# --- Application encryption (required for tenant SMTP passwords at rest, PII fields, etc.) ---
APP_ENCRYPTION_KEY=replace_with_32_byte_base64_encoded_key

# Outbound email (e.g. contract send) is configured per tenant in the app: Settings → Outbound email (SMTP + From).
# Typical provider: Resend — host smtp.resend.com, port 587, username resend, password = API key, From = verified sender.

# --- Docker Image Config ---
DOCKER_REGISTRY=registry.digitalocean.com/arqops
IMAGE_TAG=latest
# Optional: for infra/prod/scripts/build-push-images.sh (default docker)
# CONTAINER_ENGINE=podman

# --- Caddy / Domain ---
# App site hostnames for Caddy (comma then SPACE between names — Caddy rejects "a,b" without the space).
# Caddy redirects www.{CANONICAL_APP_HOST} → https://{CANONICAL_APP_HOST}{uri}
APP_DOMAIN=arqops.com, www.arqops.com
CANONICAL_APP_HOST=arqops.com
API_DOMAIN=api.arqops.com
# Optional: passed only to reverse-proxy for compose interpolation (defaults in docker-compose.prod.yml match these).
# CORS_ORIGIN must match the browser origin after redirects — use the apex URL (https://arqops.com), not www.
# Browser API base: https://api.* (cross-origin) requires CORS_ORIGIN to match exactly (no trailing slash).
# If the API is down (502), the browser often reports a CORS error instead — fix backend/DB first.
# Same-origin option (no browser CORS): PUBLIC_API_URL=https://arqops.com and rebuild frontend; Caddy routes /api/* to the backend.
PUBLIC_API_URL=https://api.arqops.com
CORS_ORIGIN=https://arqops.com
ACME_EMAIL=admin@arqops.com

# --- Local / rootless Podman only (omit on the Droplet) ---
# Privileged ports 80/443 fail under rootless Podman (e.g. macOS). Map Caddy to high ports:
# CADDY_PUBLISH_HTTP_PORT=8080
# CADDY_PUBLISH_HTTPS_PORT=8443
# Then open https://localhost:8443 (HTTP → http://localhost:8080). Let's Encrypt hostnames in Caddyfile still apply inside the container; for pure local testing use dev compose or point /etc/hosts at localhost and expect cert warnings unless you adjust the Caddyfile.
