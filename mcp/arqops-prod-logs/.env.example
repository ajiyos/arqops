# Droplet SSH (key-based auth; BatchMode=yes — no password prompt)
ARQOPS_PROD_SSH_HOST=your.droplet.ip.or.dns
ARQOPS_PROD_SSH_USER=root

# Optional: default ~/.ssh/id_rsa etc. if not used
# ARQOPS_PROD_SSH_IDENTITY_FILE=/Users/you/.ssh/do_arqops

# Remote paths (must match deploy layout)
ARQOPS_PROD_REMOTE_DIR=/opt/arqops
ARQOPS_PROD_COMPOSE_FILE=docker-compose.prod.yml
ARQOPS_PROD_ENV_FILE=.env.prod

# Use "1" if the server runs `podman compose` (plugin) instead of `podman-compose` CLI
# ARQOPS_PROD_PODMAN_COMPOSE_PLUGIN=0
