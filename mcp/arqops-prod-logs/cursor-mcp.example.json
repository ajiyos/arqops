{
  "mcpServers": {
    "arqops-prod-logs": {
      "command": "node",
      "args": ["REPLACE_WITH_MONOLITH_PATH/mcp/arqops-prod-logs/dist/index.js"],
      "env": {
        "ARQOPS_PROD_SSH_HOST": "YOUR_DROPLET_IP_OR_DNS",
        "ARQOPS_PROD_SSH_USER": "root",
        "ARQOPS_PROD_REMOTE_DIR": "/opt/arqops",
        "ARQOPS_PROD_COMPOSE_FILE": "docker-compose.prod.yml",
        "ARQOPS_PROD_ENV_FILE": ".env.prod"
      }
    }
  }
}
