# Repository root (required for arqops_docker_logs)
ARQOPS_PROJECT_ROOT=/absolute/path/to/Monolith

# auto | docker | podman | podman-compose
ARQOPS_COMPOSE_BACKEND=auto

# compose file relative to ARQOPS_PROJECT_ROOT
ARQOPS_DOCKER_COMPOSE_FILE=docker-compose.dev.yml

# Optional: docker compose project name (-p)
# ARQOPS_DOCKER_COMPOSE_PROJECT=monolith

# PostgreSQL (defaults match docker-compose.dev.yml published port)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=architect_saas
POSTGRES_USER=architect_user
POSTGRES_PASSWORD=architect_pass

# Managed Postgres / production TLS
# POSTGRES_SSL=true
# POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# Spring Boot health check
ARQOPS_BACKEND_HEALTH_URL=http://localhost:8080/actuator/health
